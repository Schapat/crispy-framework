#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: governance-intake [options]

Collect project-start governance answers and write markdown artifacts.

Options:
  -d, --directory <path>  Target project directory. Defaults to current directory.
      --answers <path>    Read answers from KEY=VALUE file instead of prompting.
  -y, --yes              Skip final confirmation prompt.
      --force            Overwrite existing generated files after backup.
      --dry-run          Show planned files without writing.
  -h, --help             Show this help.

Generated artifacts:
  docs/intake/INTAKE-project-start.md
  docs/product/overview.md
  docs/stories/backlog.md
  docs/TEST_MATRIX.md
  docs/decisions/0001-project-start-governance.md

This command writes governance artifacts only. It does not scaffold application
source, package scripts, CI, platform shells, or implementation code.
EOF
}

log() {
  printf '%s\n' "$*"
}

fail() {
  printf 'Error: %s\n' "$*" >&2
  exit 1
}

ORIGINAL_STTY=""
TTY_READY=0

can_prompt() {
  [ -r /dev/tty ] && [ -w /dev/tty ]
}

setup_tty() {
  if [ "$TTY_READY" -eq 1 ]; then
    return 0
  fi

  can_prompt || return 1
  ORIGINAL_STTY="$(stty -g < /dev/tty 2>/dev/null || true)"
  exec 3</dev/tty
  exec 4>/dev/tty
  TTY_READY=1
  stty sane intr '^C' erase '^?' < /dev/tty 2>/dev/null || true
}

restore_tty() {
  if [ "$TTY_READY" -eq 1 ] && [ -n "$ORIGINAL_STTY" ]; then
    stty "$ORIGINAL_STTY" < /dev/tty 2>/dev/null || true
  fi
}

abort_tty() {
  restore_tty
  printf '\nAborted.\n' >&2
  exit 130
}

trap restore_tty EXIT
trap abort_tty INT TERM

prompt_tty() {
  setup_tty || fail "Cannot prompt without a TTY. Use --answers <path>."
  printf '%s' "$1" >&4
}

read_tty() {
  local value
  setup_tty || fail "Cannot prompt without a TTY. Use --answers <path>."
  stty sane intr '^C' erase '^?' < /dev/tty 2>/dev/null || true
  IFS= read -r value <&3
  printf '%s\n' "$value"
}

expand_path() {
  case "$1" in
    "~")
      printf '%s\n' "$HOME"
      ;;
    "~/"*)
      printf '%s/%s\n' "$HOME" "${1#~/}"
      ;;
    /*)
      printf '%s\n' "$1"
      ;;
    *)
      printf '%s/%s\n' "$PWD" "$1"
      ;;
  esac
}

make_absolute_parent() {
  local path="$1"
  local parent
  parent="$(dirname "$path")"
  [ -d "$parent" ] || fail "Parent directory does not exist: $parent"
  (cd "$parent" && printf '%s/%s\n' "$(pwd -P)" "$(basename "$path")")
}

shell_quote() {
  local value="$1"
  printf "'%s'" "$(printf '%s' "$value" | sed "s/'/'\\\\''/g")"
}

load_answers() {
  local file="$1"
  [ -f "$file" ] || fail "Answers file does not exist: $file"

  local key
  for key in "${ANSWER_KEYS[@]}"; do
    local line value
    line="$(rg -m 1 "^${key}=" "$file" || true)"
    if [ -n "$line" ]; then
      value="${line#*=}"
      printf -v "$key" '%s' "$value"
    fi
  done
}

ask_answer() {
  local var="$1"
  local question="$2"
  local current="${!var:-}"

  if [ -n "$current" ]; then
    return
  fi

  can_prompt || fail "Cannot prompt without a TTY. Use --answers <path>."
  prompt_tty "$question "
  local value
  value="$(read_tty)"
  printf -v "$var" '%s' "$value"
}

require_answers() {
  local key
  for key in "${ANSWER_KEYS[@]}"; do
    [ -n "${!key:-}" ] || fail "Missing answer: $key"
  done
}

confirm_write() {
  [ "$YES" -eq 1 ] && return
  [ "$DRY_RUN" -eq 1 ] && return
  can_prompt || fail "Cannot confirm without a TTY. Use --yes."

  prompt_tty "Write governance artifacts into $TARGET_DIR? [y/N] "
  local reply
  reply="$(read_tty)"
  case "$reply" in
    y|Y|yes|YES) ;;
    *) fail "Aborted by user" ;;
  esac
}

backup_existing() {
  local target="$1"
  if [ ! -e "$target" ]; then
    return 0
  fi

  if [ "$FORCE" -ne 1 ]; then
    fail "Refusing to overwrite existing file without --force: ${target#$TARGET_DIR/}"
  fi

  local backup="$target.bak.$TIMESTAMP"
  if [ "$DRY_RUN" -eq 1 ]; then
    log "DRY-RUN backup ${target#$TARGET_DIR/} -> ${backup#$TARGET_DIR/}"
  else
    cp -p "$target" "$backup"
    log "BACKUP ${target#$TARGET_DIR/} -> ${backup#$TARGET_DIR/}"
  fi
}

write_file() {
  local relative="$1"
  local content="$2"
  local target="$TARGET_DIR/$relative"

  if [ "$DRY_RUN" -eq 1 ]; then
    log "DRY-RUN create $relative"
    return
  fi

  backup_existing "$target"
  mkdir -p "$(dirname "$target")"
  printf '%s\n' "$content" > "$target"
  log "CREATE $relative"
}

render_intake() {
  cat <<EOF
# Spec Intake

Date: $TODAY

## Source

- Source type: governance intake TUI
- Project name: $PROJECT_NAME

## Project Summary

$PROJECT_PURPOSE

Target users:

- $TARGET_USERS

## Main Workflows

$MAIN_WORKFLOWS

## Core Concepts

$CORE_CONCEPTS

## Product Surfaces

$SURFACES

## Sensitive Data And Risk Signals

Sensitive data:

- $SENSITIVE_DATA

Risk areas:

- $RISK_AREAS

## Candidate Product Docs

| File | Purpose | Source sections |
| --- | --- | --- |
| \`docs/product/overview.md\` | Project purpose, users, workflows, surfaces, risks, and first slice | governance intake answers |

## Candidate Epics

| Epic | Description | Status |
| --- | --- | --- |
| E01 | First useful project slice | unsliced |

## Architecture Questions

- Stack decisions: $STACK_DECISIONS
- Stack unknowns: $STACK_UNKNOWNS
- Product surfaces: $SURFACES
- Sensitive data: $SENSITIVE_DATA
- Risk areas: $RISK_AREAS

## Validation Shape

$PROOF_EXPECTATIONS

## Open Decisions

- Confirm stack choices: $STACK_UNKNOWNS
- Confirm first implementation slice: $FIRST_SLICE

## First Story Candidates

- $FIRST_SLICE

## Harness Delta

Created by governance intake TUI. No implementation code was generated.
EOF
}

render_overview() {
  cat <<EOF
# Product Overview

## Project

$PROJECT_NAME

## Purpose

$PROJECT_PURPOSE

## Target Users

$TARGET_USERS

## Main Workflows

$MAIN_WORKFLOWS

## Core Concepts

$CORE_CONCEPTS

## Product Surfaces

$SURFACES

## Sensitive Data

$SENSITIVE_DATA

## Risk Areas

$RISK_AREAS

## First Useful Slice

$FIRST_SLICE

## Proof Expectations

$PROOF_EXPECTATIONS

## Stack Notes

Accepted decisions:

- $STACK_DECISIONS

Open questions:

- $STACK_UNKNOWNS
EOF
}

render_backlog() {
  cat <<EOF
# Story Backlog

Generated by governance intake on $TODAY.

## Candidate Epics

| Epic | Description | Status |
| --- | --- | --- |
| E01 | First useful project slice for $PROJECT_NAME | unsliced |

## First Story Candidates

- $FIRST_SLICE

## Open Questions Before Story Packets

- Stack unknowns: $STACK_UNKNOWNS
- Risk areas: $RISK_AREAS
EOF
}

render_matrix() {
  cat <<EOF
# Test Matrix

This file maps accepted product or governance behavior to proof.

## Matrix

| Story | Contract | Unit | Integration | E2E | Platform | Status | Evidence |
| --- | --- | --- | --- | --- | --- | --- | --- |
| GOV-001 | Governance intake captured project purpose, users, workflows, risks, proof expectations, and first slice | no | no | no | no | implemented | \`docs/intake/INTAKE-project-start.md\`, \`docs/product/overview.md\` |
| E01-first-slice | $FIRST_SLICE | no | no | no | no | planned | none |

## Evidence Rules

- Do not mark implementation behavior complete until executable proof exists.
- Document review is acceptable only for governance artifacts before code exists.
- Stub-only or surface-only work is not implemented proof.
EOF
}

render_decision() {
  cat <<EOF
# 0001 Project Start Governance

Date: $TODAY

## Status

Proposed

## Context

The project was initialized through the governance intake TUI before
implementation work began.

## Decision

Use the harness governance flow before coding. Initial stack decisions:

- $STACK_DECISIONS

Open stack questions:

- $STACK_UNKNOWNS

## Alternatives Considered

1. Start implementation immediately. Rejected until first story and proof shape
   are accepted.

## Consequences

Positive:

- Agents have project purpose, users, risks, and proof expectations before
  coding.

Tradeoffs:

- Some product and stack details remain provisional until follow-up decisions.

## Follow-Up

- Turn first slice into a story packet: $FIRST_SLICE
EOF
}

TARGET_INPUT="$PWD"
ANSWERS_FILE=""
YES=0
FORCE=0
DRY_RUN=0
TIMESTAMP="$(date +%Y%m%d%H%M%S)"
TODAY="$(date +%Y-%m-%d)"

ANSWER_KEYS=(
  PROJECT_NAME
  PROJECT_PURPOSE
  TARGET_USERS
  MAIN_WORKFLOWS
  CORE_CONCEPTS
  SURFACES
  SENSITIVE_DATA
  RISK_AREAS
  STACK_DECISIONS
  STACK_UNKNOWNS
  PROOF_EXPECTATIONS
  FIRST_SLICE
)

for key in "${ANSWER_KEYS[@]}"; do
  printf -v "$key" '%s' ""
done

while [ "$#" -gt 0 ]; do
  case "$1" in
    -d|--directory)
      [ "$#" -ge 2 ] || fail "$1 requires a path"
      TARGET_INPUT="$2"
      shift 2
      ;;
    --answers)
      [ "$#" -ge 2 ] || fail "$1 requires a path"
      ANSWERS_FILE="$2"
      shift 2
      ;;
    -y|--yes)
      YES=1
      shift
      ;;
    --force)
      FORCE=1
      shift
      ;;
    --dry-run)
      DRY_RUN=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "Unknown option: $1"
      ;;
  esac
done

if [ -n "$ANSWERS_FILE" ]; then
  load_answers "$ANSWERS_FILE"
fi

ask_answer PROJECT_NAME "Project name:"
ask_answer PROJECT_PURPOSE "What problem does it solve?"
ask_answer TARGET_USERS "Who is it for?"
ask_answer MAIN_WORKFLOWS "Main workflows:"
ask_answer CORE_CONCEPTS "Core domain concepts:"
ask_answer SURFACES "Surfaces (browser, API, CLI, worker, mobile, desktop, service):"
ask_answer SENSITIVE_DATA "Sensitive data or difficult-to-recover data:"
ask_answer RISK_AREAS "Risk areas (auth, payments, providers, files, webhooks, etc.):"
ask_answer STACK_DECISIONS "Stack choices already decided:"
ask_answer STACK_UNKNOWNS "Stack choices still open:"
ask_answer PROOF_EXPECTATIONS "What proof should count for the first useful version?"
ask_answer FIRST_SLICE "Smallest useful first slice:"

require_answers

TARGET_DIR="$(make_absolute_parent "$(expand_path "$TARGET_INPUT")")"

if [ "$DRY_RUN" -eq 0 ]; then
  mkdir -p "$TARGET_DIR"
fi

log "Governance intake target: $TARGET_DIR"
log "Project: $PROJECT_NAME"
log ""
log "Planned artifacts:"
log "- docs/intake/INTAKE-project-start.md"
log "- docs/product/overview.md"
log "- docs/stories/backlog.md"
log "- docs/TEST_MATRIX.md"
log "- docs/decisions/0001-project-start-governance.md"
log ""

confirm_write

write_file "docs/intake/INTAKE-project-start.md" "$(render_intake)"
write_file "docs/product/overview.md" "$(render_overview)"
write_file "docs/stories/backlog.md" "$(render_backlog)"
write_file "docs/TEST_MATRIX.md" "$(render_matrix)"
write_file "docs/decisions/0001-project-start-governance.md" "$(render_decision)"

log ""
if [ "$DRY_RUN" -eq 1 ]; then
  log "Dry run complete. No files were written."
else
  log "Governance intake complete. No implementation files were generated."
fi
